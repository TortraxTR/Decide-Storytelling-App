# ----------------------------------------------------------
# Database (required)
# ----------------------------------------------------------
DATABASE_URL=postgresql://decide_admin:password@localhost:5432/decide

# ----------------------------------------------------------
# JWT Authentication
# Option 1: set JWT_SECRET directly (recommended for local dev)
# Option 2: leave JWT_SECRET unset and the app will fetch it
#            from AWS Secrets Manager using JWT_SECRET_NAME below
# ----------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string

# AWS Secrets Manager (used when JWT_SECRET is not set)
JWT_SECRET_NAME=decide/dev/JWT_SECRET
AWS_REGION=eu-central-1

# AWS credentials (only needed locally; App Runner uses its IAM role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
