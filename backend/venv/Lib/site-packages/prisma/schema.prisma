generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = "5"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Story {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  thumbnail   String?
  authorId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  episodes    Episode[]

  @@index([authorId])
}

model Episode {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storyId     String        @db.Uuid
  title       String
  description String?
  thumbnail   String?
  authorId    String
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt
  story       Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  EpisodeNode EpisodeNode[]

  @@index([storyId])
  @@index([authorId])
}

model EpisodeNode {
  id                                          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  episodeId                                   String     @db.Uuid
  contentUrl                                  String
  isStart                                     Boolean    @default(false)
  isEnd                                       Boolean    @default(false)
  Decision_Decision_sourceNodeIdToEpisodeNode Decision[] @relation("Decision_sourceNodeIdToEpisodeNode")
  Decision_Decision_targetNodeIdToEpisodeNode Decision[] @relation("Decision_targetNodeIdToEpisodeNode")
  Episode                                     Episode    @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId])
}

model Decision {
  id                                             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text                                           String?
  sourceNodeId                                   String      @db.Uuid
  targetNodeId                                   String      @db.Uuid
  EpisodeNode_Decision_sourceNodeIdToEpisodeNode EpisodeNode @relation("Decision_sourceNodeIdToEpisodeNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  EpisodeNode_Decision_targetNodeIdToEpisodeNode EpisodeNode @relation("Decision_targetNodeIdToEpisodeNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([sourceNodeId])
  @@index([targetNodeId])
}
