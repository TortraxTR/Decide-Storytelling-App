generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = "5"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User-related Models
model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  username  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    Author?
  reader    Reader?
}

model Author {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories   Story[]
}

model Reader {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Narrative Engine
model Story {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  thumbnail   String?   @db.VarChar(2048)
  authorId    String    @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  episodes    Episode[]
  author      Author    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
}

model Episode {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storyId     String        @db.Uuid
  title       String
  description String?
  thumbnail   String?       @db.VarChar(2048)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  story       Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  nodes       EpisodeNode[]
  decisions   Decision[]

  @@unique([storyId, order])
  @@index([storyId, order])
}

model EpisodeNode {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  episodeId         String     @db.Uuid
  contentUrl        String     @db.VarChar(2048)
  isStart           Boolean    @default(false)
  isEnd             Boolean    @default(false)
  episode           Episode    @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  outgoingDecisions Decision[] @relation("SourceNode")
  incomingDecisions Decision[] @relation("TargetNode")

  @@unique([id, episodeId])
  @@index([episodeId])
}

model Decision {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text         String?
  episodeId    String  @db.Uuid
  sourceNodeId String  @db.Uuid
  targetNodeId String  @db.Uuid

  episode    Episode     @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  sourceNode EpisodeNode @relation("SourceNode", fields: [sourceNodeId, episodeId], references: [id, episodeId], onDelete: Cascade)
  targetNode EpisodeNode @relation("TargetNode", fields: [targetNodeId, episodeId], references: [id, episodeId], onDelete: Cascade)

  @@index([episodeId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
}
