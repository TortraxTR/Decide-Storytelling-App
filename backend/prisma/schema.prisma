// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Story {
  id          String      @id @default(uuid())
  title       String
  description String?
  thumbnail   String?     // Local path for now, S3 URL later
  authorId    String      
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  nodes       StoryNode[]
}

model StoryNode {
  id          String   @id @default(uuid())
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  contentUrl  String   // Local /assets/ path for now
  isStart     Boolean  @default(false)
  isEnd       Boolean  @default(false)

  // --- The Flattened Binary Arcs ---
  
  choiceAText     String?
  choiceATargetId String?
  choiceATarget   StoryNode? @relation("ChoiceA", fields: [choiceATargetId], references: [id])

  choiceBText     String?
  choiceBTargetId String?
  choiceBTarget   StoryNode? @relation("ChoiceB", fields: [choiceBTargetId], references: [id])

  // Required back-relations so Prisma knows how the self-referential graph resolves
  incomingChoiceA StoryNode[] @relation("ChoiceA")
  incomingChoiceB StoryNode[] @relation("ChoiceB")
}
