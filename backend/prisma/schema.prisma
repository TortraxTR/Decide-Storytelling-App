generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = "5"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  username     String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  passwordHash String?
  author       Author?
  reader       Reader?
}

model Author {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories   Story[]
}

model Reader {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String          @unique @db.Uuid
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  readSessions ReadSession[]
  favorites    StoryFavorite[]
  ratings      StoryRating[]
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Story {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  thumbnail   String?         @db.VarChar(2048)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  authorId    String          @db.Uuid
  status      PublishStatus   @default(DRAFT)
  episodes    Episode[]
  favorites   StoryFavorite[]
  ratings     StoryRating[]
  author      Author          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
}

model Episode {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storyId      String        @db.Uuid
  title        String
  order        Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  status       PublishStatus @default(DRAFT)
  decisions    Decision[]
  story        Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  nodes        EpisodeNode[]
  readSessions ReadSession[]

  @@unique([storyId, order])
  @@index([storyId, order])
}

model EpisodeNode {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  episodeId         String        @db.Uuid
  assetHeight       Int?
  assetKey          String        @db.VarChar(1024)
  assetWidth        Int?
  canvasX           Float?
  canvasY           Float?
  textField         String?
  outgoingDecisions Decision[]    @relation("SourceNode")
  incomingDecisions Decision[]    @relation("TargetNode")
  episode           Episode       @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  readSessions      ReadSession[]

  @@unique([id, episodeId])
  @@index([episodeId])
}

model Decision {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text         String?
  sourceNodeId String      @db.Uuid
  targetNodeId String      @db.Uuid
  episodeId    String      @db.Uuid
  episode      Episode     @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  sourceNode   EpisodeNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode   EpisodeNode @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([episodeId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
}

model ReadSession {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  readerId      String      @db.Uuid
  episodeId     String      @db.Uuid
  currentNodeId String      @db.Uuid
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  currentNode   EpisodeNode @relation(fields: [currentNodeId], references: [id])
  episode       Episode     @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  reader        Reader      @relation(fields: [readerId], references: [id], onDelete: Cascade)

  @@unique([readerId, episodeId])
  @@index([readerId])
}

/// Library entry: reader bookmarked a story.
model StoryFavorite {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  readerId  String   @db.Uuid
  storyId   String   @db.Uuid
  createdAt DateTime @default(now())
  reader    Reader   @relation(fields: [readerId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([readerId, storyId])
  @@index([readerId])
  @@index([storyId])
}

/// Per-reader story reaction (1 = thumbs up). Unique per reader+story.
model StoryRating {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  readerId  String   @db.Uuid
  storyId   String   @db.Uuid
  value     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reader    Reader   @relation(fields: [readerId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([readerId, storyId])
  @@index([storyId])
  @@index([readerId])
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
